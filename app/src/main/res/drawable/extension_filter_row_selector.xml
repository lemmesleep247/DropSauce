<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
	<item android:state_enabled="true" android:state_pressed="true">
		<inset
			android:insetBottom="@dimen/menu_popup_selector_inset_vertical"
			android:insetLeft="@dimen/menu_popup_selector_inset_horizontal"
			android:insetRight="@dimen/menu_popup_selector_inset_horizontal"
			android:insetTop="@dimen/menu_popup_selector_inset_vertical">
			<shape>
				<solid android:color="@color/selector_overlay" />
				<corners android:radius="8dp" />
			</shape>
		</inset>
	</item>
	<item android:state_enabled="true" android:state_focused="true">
		<inset
			android:insetBottom="@dimen/menu_popup_selector_inset_vertical"
			android:insetLeft="@dimen/menu_popup_selector_inset_horizontal"
			android:insetRight="@dimen/menu_popup_selector_inset_horizontal"
			android:insetTop="@dimen/menu_popup_selector_inset_vertical">
			<shape>
				<solid android:color="@color/selector_overlay" />
				<corners android:radius="8dp" />
			</shape>
		</inset>
	</item>
	<item android:drawable="@android:color/transparent" />
</selector>
