<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:background="?selectableItemBackground"
	android:gravity="center_vertical"
	android:minHeight="?listPreferredItemHeightSmall"
	android:orientation="horizontal"
	android:paddingStart="?listPreferredItemPaddingStart"
	android:paddingTop="4dp"
	android:paddingBottom="4dp"
	tools:ignore="RtlSymmetry">

	<FrameLayout
		android:layout_width="44dp"
		android:layout_height="44dp"
		android:foregroundGravity="center">

		<org.koitharu.kotatsu.core.ui.image.FaviconView
			android:id="@+id/imageView_icon"
			android:layout_width="32dp"
			android:layout_height="32dp"
			android:layout_gravity="center"
			android:background="?colorControlHighlight"
			android:labelFor="@id/textView_title"
			android:scaleType="fitCenter"
			app:iconStyle="@style/FaviconDrawable.Small"
			app:shapeAppearance="?shapeAppearanceCornerSmall"
			tools:src="@tools:sample/avatars" />

		<com.google.android.material.loadingindicator.LoadingIndicator
			android:id="@+id/progress_icon"
			android:layout_width="44dp"
			android:layout_height="44dp"
			android:layout_gravity="center"
			android:visibility="gone"
			app:containerHeight="44dp"
			app:containerWidth="44dp"
			app:indicatorColor="?attr/colorPrimary"
			app:indicatorSize="34dp" />
	</FrameLayout>

	<LinearLayout
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_marginStart="?android:listPreferredItemPaddingStart"
		android:layout_marginEnd="?android:listPreferredItemPaddingEnd"
		android:layout_weight="1"
		android:orientation="vertical">

		<TextView
			android:id="@+id/textView_title"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:ellipsize="end"
			android:singleLine="true"
			android:textAppearance="?attr/textAppearanceTitleSmall"
			tools:text="@tools:sample/lorem[15]" />

		<TextView
			android:id="@+id/textView_description"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="2dp"
			android:drawablePadding="4dp"
			android:ellipsize="end"
			android:gravity="center_vertical"
			android:singleLine="true"
			android:textAppearance="?attr/textAppearanceBodySmall"
			tools:drawableStart="@drawable/ic_off_small"
			tools:text="English" />

	</LinearLayout>

	<com.google.android.material.button.MaterialButtonGroup
		android:id="@+id/buttonGroup_actions"
		style="@style/Widget.Material3Expressive.MaterialButtonGroup.Connected"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginEnd="6dp"
		android:spacing="2dp">

		<com.google.android.material.button.MaterialButton
			android:id="@+id/imageView_hide"
			style="?attr/materialIconButtonFilledTonalStyle"
			android:layout_width="@dimen/extension_action_button_size"
			android:layout_height="@dimen/extension_action_button_size"
			android:contentDescription="@string/hide"
			android:insetBottom="0dp"
			android:insetLeft="0dp"
			android:insetRight="0dp"
			android:insetTop="0dp"
			android:minWidth="0dp"
			android:minHeight="0dp"
			android:padding="0dp"
			android:tooltipText="@string/hide"
			android:visibility="gone"
			app:icon="@drawable/ic_eye"
			app:iconGravity="textStart"
			app:iconPadding="0dp"
			app:iconSize="22dp" />

		<com.google.android.material.button.MaterialButton
			android:id="@+id/imageView_settings"
			style="?attr/materialIconButtonFilledTonalStyle"
			android:layout_width="@dimen/extension_action_button_size"
			android:layout_height="@dimen/extension_action_button_size"
			android:contentDescription="@string/settings"
			android:insetBottom="0dp"
			android:insetLeft="0dp"
			android:insetRight="0dp"
			android:insetTop="0dp"
			android:minWidth="0dp"
			android:minHeight="0dp"
			android:padding="0dp"
			android:tooltipText="@string/settings"
			android:visibility="gone"
			app:icon="@drawable/ic_settings"
			app:iconGravity="textStart"
			app:iconPadding="0dp"
			app:iconSize="22dp" />

		<com.google.android.material.button.MaterialButton
			android:id="@+id/imageView_add"
			style="?attr/materialIconButtonFilledTonalStyle"
			android:layout_width="@dimen/extension_action_button_size"
			android:layout_height="@dimen/extension_action_button_size"
			android:contentDescription="@string/add"
			android:insetBottom="0dp"
			android:insetLeft="0dp"
			android:insetRight="0dp"
			android:insetTop="0dp"
			android:minWidth="0dp"
			android:minHeight="0dp"
			android:padding="0dp"
			android:tooltipText="@string/add"
			app:icon="@drawable/ic_add"
			app:iconGravity="textStart"
			app:iconPadding="0dp"
			app:iconSize="22dp" />
	</com.google.android.material.button.MaterialButtonGroup>

</LinearLayout>
