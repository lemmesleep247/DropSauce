<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:id="@+id/widget_continue_reading_empty_root"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@drawable/bg_appwidget_root"
	android:gravity="center"
	android:orientation="vertical"
	android:padding="14dp"
	android:theme="@style/Theme.Kotatsu.AppWidgetContainer">

	<ImageView
		android:layout_width="32dp"
		android:layout_height="32dp"
		android:src="@drawable/ic_history"
		android:contentDescription="@null"
		app:tint="@color/kotatsu_onSurfaceVariant" />

	<TextView
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginTop="8dp"
		android:gravity="center"
		android:text="@string/widget_continue_reading_empty"
		android:textColor="@color/kotatsu_onSurfaceVariant"
		android:textSize="13sp" />
</LinearLayout>
