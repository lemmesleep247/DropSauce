<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/widget_stats_root"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@drawable/bg_appwidget_root"
	android:gravity="center_vertical"
	android:orientation="vertical"
	android:padding="12dp"
	android:theme="@style/Theme.Kotatsu.AppWidgetContainer">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:gravity="center_vertical"
		android:orientation="horizontal">

		<TextView
			android:id="@+id/widget_stats_today_value"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:textColor="@color/kotatsu_onSurface"
			android:textSize="22sp"
			android:textStyle="bold"
			android:includeFontPadding="false"
			tools:text="1h 24m" />

		<TextView
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginStart="8dp"
			android:background="@drawable/bg_appwidget_chip"
			android:paddingHorizontal="9dp"
			android:paddingVertical="2dp"
			android:text="@string/widget_stats_today"
			android:textColor="@color/kotatsu_onPrimaryContainer"
			android:textSize="10sp"
			android:textStyle="bold"
			android:letterSpacing="0.05" />
	</LinearLayout>

	<TextView
		android:id="@+id/widget_stats_subtitle"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginTop="2dp"
		android:textColor="@color/kotatsu_onSurfaceVariant"
		android:textSize="11sp"
		tools:text="3-day streak" />
</LinearLayout>
